{
  "name": "ai-assessment-creator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "dev:infra": "docker-compose up -d",
    "dev:backend": "cd backend && npm run dev",
    "dev:worker": "cd backend && npm run worker",
